rrel_cubic_meter
    <- sc_node_role_relation;
    => nrel_main_idtf:
        [м³'] (* <- lang_ru;; *);
        [m³'] (* <- lang_en;; *);
    <- role_relation;;

rrel_kg_per_cubic_meter
    <- sc_node_role_relation;
    => nrel_main_idtf:
        [кг/м³'] (* <- lang_ru;; *);
        [kg/m³'] (* <- lang_en;; *);
    <- role_relation;;

nrel_volume
    <- sc_node_non_role_relation;
    => nrel_main_idtf:
        [объём*] (* <- lang_ru;; *);
        [volume*] (* <- lang_en;; *);
    <- binary_relation;
    => nrel_first_domain: cargo;
    => nrel_second_domain: number;;

nrel_density
    <- sc_node_non_role_relation;
    => nrel_main_idtf:
        [плотность*] (* <- lang_ru;; *);
        [density*] (* <- lang_en;; *);
    <- binary_relation;
    => nrel_first_domain: cargo;
    => nrel_second_domain: number;;

nrel_warehouse_capacity
    <- sc_node_non_role_relation;
    => nrel_main_idtf:
        [вместимость склада*] (* <- lang_ru;; *);
        [warehouse capacity*] (* <- lang_en;; *);
    <- binary_relation;
    => nrel_first_domain: warehouse;
    => nrel_second_domain: number;;

nrel_warehouse_area
    <- sc_node_non_role_relation;
