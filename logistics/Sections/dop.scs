rrel_liter
	<- sc_node_role_relation;
	<- role_relation;
	=> nrel_main_idtf:
		[liter']
		(*<- lang_en;;*);
		[литр']
		(*<- lang_ru;;*);

	=> nrel_first_domain: 
		set;
	=> nrel_second_domain: 
		number;;

