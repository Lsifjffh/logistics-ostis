        [предыдущее звено'] (* <- lang_ru;; *);
        [previous link'] (* <- lang_en;; *);
    <- binary_relation;
    => nrel_first_domain: supply_chain_link;
    => nrel_second_domain: supply_chain_link;;

nrel_next_link <- sc_node_role_relation;
