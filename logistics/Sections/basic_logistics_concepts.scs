logistics_operation
    <- sc_node_class;
    => nrel_main_idtf:
        [логистическая операция] (* <- lang_ru;; *);
        [logistics operation] (* <- lang_en;; *);

    <- rrel_key_sc_element: ...
    (*
        <- definition;;
        => nrel_main_idtf: 
            [Опр. (логистическая операция)]
            (*<- lang_ru;;*);;
        <= nrel_sc_text_translation:...
        (*
            -> rrel_example:
                [<b>Логистическая операция</b> — это элементарное действие, направленное на преобразование материального или информационного потока. Примеры: погрузка, разгрузка, комплектация, маркировка.]
                (*
                    <- lang_ru;;
                    => nrel_format: format_html;;
                *);;
        *);;
    *);;

nrel_consists_of_operations <- sc_node_non_role_relation;
    => nrel_main_idtf:
        [состоит из операций*] (* <- lang_ru;; *);
        [consists of operations*] (* <- lang_en;; *);
    <- binary_relation;
    <- oriented_relation;
    => nrel_first_domain: logistical_process;
    => nrel_second_domain: logistics_operation;;

supply_chain
    <- sc_node_class;
    => nrel_main_idtf:
        [цепь поставок] (* <- lang_ru;; *);
        [supply chain] (* <- lang_en;; *);
    => nrel_idtf:
        [логистическая цепь] (* <- lang_ru;; *);
