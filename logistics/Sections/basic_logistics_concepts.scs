logistics_system
    <- sc_node_class;
    => nrel_main_idtf:
        [логистическая система] (* <- lang_ru;; *);
        [logistics system] (* <- lang_en;; *);

    <- rrel_key_sc_element: ...
    (*
        <- definition;;
        => nrel_main_idtf: 
            [Опр. (логистическая система)]
            (*<- lang_ru;;*);;
        <= nrel_sc_text_translation:...
        (*
            -> rrel_example:
                [<b>Логистическая система</b> — это совокупность элементов (поставщиков, складов, транспорта, потребителей), связанных логистическими процессами и объединённых единой целью управления материальными и информационными потоками.]
                (*
                    <- lang_ru;;
                    => nrel_format: format_html;;
                *);;
        *);;
    *);;

logistics_function
    <- sc_node_class;
    => nrel_main_idtf:
        [логистическая функция] (* <- lang_ru;; *);
        [logistics function] (* <- lang_en;; *);

    <- rrel_key_sc_element: ...
    (*
        <- definition;;
        => nrel_main_idtf: 
            [Опр. (логистическая функция)]
            (*<- lang_ru;;*);;
        <= nrel_sc_text_translation:...
        (*
            -> rrel_example:
                [<b>Логистическая функция</b> — это укрупнённая совокупность логистических операций, направленная на реализацию целей логистической системы.]
                (*
                    <- lang_ru;;
                    => nrel_format: format_html;;
                *);;
        *);;
    *);;

transportation_function <- sc_node_class;
    => nrel_main_idtf:
        [транспортировка] (* <- lang_ru;; *);
        [transportation] (* <- lang_en;; *);
    <= nrel_inclusion: logistics_function;;

