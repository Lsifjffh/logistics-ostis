    <- rrel_key_sc_element: ...
    (*
        <- definition;;
        => nrel_main_idtf: 
            [Опр. (цепь поставок)]
            (*<- lang_ru;;*);;
        <= nrel_sc_text_translation:...
        (*
            -> rrel_example:
                [<b>Цепь поставок</b> — это последовательность звеньев (поставщик, производитель, дистрибьютор, розничный продавец, потребитель), через которые товар проходит от источника сырья до конечного потребителя.]
                (*
                    <- lang_ru;;
                    => nrel_format: format_html;;
                *);;
        *);;
    *);;

