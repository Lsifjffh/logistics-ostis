farm
	<- sc_node_class;
	=> nrel_main_idtf:
		[farm]
		(*<- lang_en;;*);
		[ферма]
		(*<- lang_ru;;*);

	=> nrel_idtf:
		[фермерское хозяйство]
		(*<- lang_ru;;*);

	<- rrel_key_sc_element: ...
	(*
		<- definition;;
		=> nrel_main_idtf: 
			[Опр. (ферма)]
			(*<- lang_ru;;*);;
		<= nrel_sc_text_translation: ...
		(*
			-> rrel_example:
                [<b>Ферма</b> — частное сельскохозяйственное предприятие, занимающееся производством сельскохозяйственной продукции.]
				(*
					<- lang_ru;;
					=> nrel_format: format_html;;
				*);;
		*);;
	*);;

ruzhany_agro_farm
=> nrel_main_idtf:
	[Ферма "Ружаны-Агро"] 
	(* <- lang_ru;; *);
	["Ruzhany-Agro" farm]
        (*<- lang_en;;*);
<- farm;
=> nrel_nearest_locality: Ruzhany;
=> nrel_area: ...
	(*
		<- value;;
		<= nrel_measurement:...
		(*
			-> rrel_hectare: 20511 (*<- number;;*);;
		*);;
	*);
=>nrel_main_crop_sector:
    cereals;
    rapeseed;
    potato;

=>nrel_main_livestock_sector:
    dairy_cattle_breeding;;


