factory
	<- sc_node_class;
	=> nrel_main_idtf:
		[factory]
		(*<- lang_en;;*);
		[фабрика]
		(*<- lang_ru;;*);

	=> nrel_idtf:
        [plant]
		(*<- lang_en;;*);
		[завод]
		(*<- lang_ru;;*);

	<- rrel_key_sc_element: ...
	(*
		<- definition;;
		=> nrel_main_idtf: 
			[Опр. (фабрика)]
			(*<- lang_ru;;*);;
		<= nrel_sc_text_translation: ...
		(*
			-> rrel_example:
                [<b>Фабрика</b> — промышленное предприятие, основанное на применении машин, характеризующееся крупномасштабным производством]
               (*
					<- lang_ru;;
					=> nrel_format: format_html;;
				*);;
		*);;
	*);;


